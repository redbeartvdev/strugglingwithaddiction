# Local dev: leave empty — Vite proxies /api → http://127.0.0.1:8000
# Production (Railway monolith): leave VITE_API_URL empty for same-origin /api
VITE_API_URL=
# Optional: production helpline (digits only, e.g. 18005551234)
VITE_HELPLINE_NUMBER=
# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXX)
VITE_GA_MEASUREMENT_ID=
