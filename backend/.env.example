DATABASE_URL=postgresql://swa:swa_dev_password@localhost:5433/swa
# Production (Railway): reference Postgres DATABASE_URL from Railway dashboard
# Railway may use postgres:// — the app normalizes it automatically

JWT_SECRET=change-me-in-production-use-long-random-string
# Production: openssl rand -hex 32

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ENVIRONMENT=development
# Production: ENVIRONMENT=production

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5180
# Production: https://your-app.up.railway.app,https://your-app.up.railway.app/admin

ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=changeme123
# Only used when no admin user exists (first deploy)

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

PUBLIC_SITE_URL=http://localhost:5173
ADMIN_SITE_URL=http://localhost:5180
# Production: your Railway app URL (+ /admin for admin)

S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=swa-uploads
S3_PUBLIC_URL=
UPLOAD_DIR=uploads
