# Copy to railway-setup.env, fill in, then from repo root:
#   set -a && source backend/scripts/railway-setup.env && set +a
#   ./backend/scripts/railway-setup.sh

# Your Railway service name (see Railway dashboard)
RAILWAY_API_SERVICE=strugglingwithaddiction-production

# Optional if domain already exists:
# PUBLIC_SITE_URL=https://strugglingwithaddiction-production.up.railway.app

# RAILWAY_POSTGRES_SERVICE=Postgres
# ADMIN_BOOTSTRAP_EMAIL=you@example.com
# ADMIN_BOOTSTRAP_PASSWORD=your-secure-password
