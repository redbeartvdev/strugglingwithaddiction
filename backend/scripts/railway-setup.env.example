# Copy to railway-setup.env, fill in, then:
#   set -a && source scripts/railway-setup.env && set +a
#   ./scripts/railway-setup.sh

# Netlify (or other) frontend URLs — required unless CORS_ORIGINS is set
PUBLIC_SITE_URL=https://your-public-site.netlify.app
ADMIN_SITE_URL=https://your-admin-site.netlify.app

# Optional: override defaults
# RAILWAY_API_SERVICE=strugglingwithaddiction
# RAILWAY_POSTGRES_SERVICE=Postgres
# CORS_ORIGINS=https://site-a.netlify.app,https://site-b.netlify.app
# ADMIN_BOOTSTRAP_EMAIL=you@example.com
# ADMIN_BOOTSTRAP_PASSWORD=your-secure-password
