# Copy to railway-setup.env, fill in, then from repo root:
#   set -a && source backend/scripts/railway-setup.env && set +a
#   ./backend/scripts/railway-setup.sh

# Railway project + API service
RAILWAY_PROJECT_ID=407fa40d-6608-4441-905c-f3fab0182421
RAILWAY_API_SERVICE=strugglingwithaddiction-production

# Optional if domain already exists:
